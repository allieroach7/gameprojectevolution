draw_set_halign(fa_center);
draw_set_valign(fa_middle);

draw_set_colour(c_lime);
draw_text(room_width / 2, room_height / 3, "YOU EVOLVED INTO A HUMAN!");

draw_set_colour(c_white);
draw_text(room_width / 2, room_height / 2, "Congratulations! You survived.");

draw_set_colour(c_gray);
draw_text(room_width / 2, room_height * 0.65, "Press ENTER to Play Again");

draw_set_halign(fa_left);
draw_set_valign(fa_top);